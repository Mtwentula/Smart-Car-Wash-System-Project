# Copy to .env for local development overrides.

# Database
DB_URL=jdbc:postgresql://localhost:5432/int216d_carwash
DB_USER=dev
DB_PASSWORD=dev

# JWT — change in production!
JWT_SECRET=int216d-super-secret-key-change-in-production-must-be-at-least-256-bits-long
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# Mail (MailHog locally)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@int216d.co.za

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
